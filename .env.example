# Oxlo Proxy — OpenAI-compatible proxy for Oxlo.ai free tier
# Auto-mints accounts via mail.tm, rotates on rate limits.

# Required: Postgres connection string (Supabase / Neon / Koyeb-managed PG)
DATABASE_URL=postgresql://...

# Client key for /v1/* endpoints (set to a strong random string)
PROXY_API_KEY=changeme

# Admin token for /admin/* (closed until set)
ADMIN_TOKEN=changeme

# Optional: listen config (defaults below)
# OXLO_PORT=8761
# OXLO_HOST=127.0.0.1  # Docker: 0.0.0.0
# PORT=8761            # Koyeb injects PORT

# Seed accounts on first boot (newline/comma; raw JWT or devtools blob).
# Idempotent — deduped into Postgres, then manage live via /admin/add or /admin/mint.
# OXLO_TOKENS=eyJ...ACCOUNT1,eyJ...ACCOUNT2

# Telegram control (optional). Token from @BotFather, chat id from @userinfobot:
# TELEGRAM_BOT_TOKEN=123456:AA...
# TELEGRAM_CHAT_ID=123456789
